{
  "name": "liminal-agents",
  "version": "0.2.0",
  "description": "A CLI surface on the Liminal substrate. Background daemon ingests signals from local sources, bounded agents deliberate on them, and your correction becomes data.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Shruti Rajagopal <shruti@theliminalspace.io>",
  "homepage": "https://github.com/liminalshruti/liminal-agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/liminalshruti/liminal-agents.git"
  },
  "bin": {
    "liminal-substrated": "bin/liminal-substrated.js",
    "liminal-surface": "bin/liminal-surface.js",
    "liminal-tui": "bin/liminal-tui.js"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "tui": "node bin/liminal-tui.js",
    "agency": "node skills/agency/run.js",
    "seed:demo": "node scripts/seed-demo.js",
    "daemon:install": "bash scripts/install-daemon.sh",
    "daemon:uninstall": "bash scripts/uninstall-daemon.sh",
    "test": "node --test test/*.test.js",
    "test:orchestrator": "node --test test/orchestrator.test.js",
    "test:ingest": "node --test test/daemon-ingest.test.js",
    "test:surfacing": "node --test test/surfacing-flow.test.js",
    "test:crypto": "node --test test/vault-crypto.test.js",
    "vault:migrate": "node scripts/migrate-encrypt.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "pino": "^9.5.0",
    "react": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
